# GroupMe API Configuration
# Copy this file to .env and fill in your actual values

# Your GroupMe API token (get from https://dev.groupme.com/)
GROUPME_TOKEN=your_groupme_api_token_here

# Your GroupMe group ID (found in group URL or API responses)
GROUPME_GROUP_ID=your_group_id_here

# Optional: Custom paths for production deployment
# GROUPME_DB_PATH=/opt/groupme/groupme.sqlite
# GROUPME_TMP_DIR=/opt/groupme/tmp
# GROUPME_SNAPSHOT_DEST=/mnt/groupme_snapshots
# GROUPME_LOCKFILE=/opt/groupme/snapshot.lock
# GROUPME_ERRLOG=/opt/groupme/snapshot.err
