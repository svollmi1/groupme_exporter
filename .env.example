# GroupMe Exporter Configuration
# On the host, copy this file to /etc/groupme.env and fill in your values.
# The systemd service loads this file automatically via EnvironmentFile=.

# ── Required ──────────────────────────────────────────────────────────────────

# GroupMe API token — get yours at https://dev.groupme.com/
GROUPME_TOKEN=your_groupme_api_token_here

# Numeric ID of the GroupMe group to archive.
# To find it: GET https://api.groupme.com/v3/groups?token=YOUR_TOKEN
# and look for the "id" field of the group you want.
GROUPME_GROUP_ID=your_group_id_here

# ── Deployment ────────────────────────────────────────────────────────────────

# Directory where the app is installed (venv/, groupme_ingest.py, etc.)
GROUPME_INSTALL_DIR=/opt/groupme

# ── Snapshot paths (optional — defaults shown) ────────────────────────────────

# Path to the SQLite database file
# GROUPME_DB_PATH=/opt/groupme/groupme.sqlite

# Temporary working directory for snapshot.sh
# GROUPME_TMP_DIR=/opt/groupme/tmp

# Destination directory for snapshots (must be mounted before snapshot runs)
# GROUPME_SNAPSHOT_DEST=/mnt/groupme_snapshots

# Lock file used to prevent concurrent snapshot runs
# GROUPME_LOCKFILE=/opt/groupme/snapshot.lock

# Error log for snapshot failures
# GROUPME_ERRLOG=/opt/groupme/snapshot.err
